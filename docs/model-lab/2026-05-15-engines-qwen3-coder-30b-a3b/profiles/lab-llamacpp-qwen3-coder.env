# Phase 4 engine comparison: llama.cpp llama-server on Qwen3-Coder-30B-A3B-Instruct
# GGUF Q4_K_M (~18 GB on disk) from giladgd/Qwen3-Coder-30B-A3B-Instruct-Q4_K_M-GGUF.
# Split across both 3090s with -ts 1,1 (50/50). 32K context to keep parity with
# the SGLang run; vLLM ran the same model at 64K AWQ for reference.

LAB_NAME=llamacpp-qwen3-coder-30b-a3b-q4km
LAB_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
LAB_GPUS=all
LAB_PORT=8012
LAB_API_KEY=lab-llamacpp-qwen3-coder
LAB_MODEL_PATH=/mnt/data/models/gguf/qwen3-coder-30b-a3b-q4km/qwen3-coder-30b-a3b-instruct-q4_k_m.gguf
LAB_SERVED_NAME=lab-llamacpp-qwen3-coder-30b-a3b-q4km

LAB_ENV_VARS=""

# -ngl 999: offload everything to GPU.
# -ts 1,1: tensor split 50/50 between the two 3090s.
# -fa: flash attention.
# --jinja: use the model's built-in chat template.
# -c 32768: 32K context to match SGLang and stay within VRAM headroom.
# --metrics: enable Prometheus metrics endpoint.
# --threads-http: enough HTTP workers for concurrency 16 sweep.
LAB_LLAMACPP_ARGS="\
  -ngl 999 \
  -ts 1,1 \
  -fa on \
  --jinja \
  -c 131072 \
  --parallel 4 \
  --threads-http 8 \
  --metrics"
