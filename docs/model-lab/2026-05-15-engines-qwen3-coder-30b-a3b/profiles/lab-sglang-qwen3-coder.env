# Phase 4 engine comparison: SGLang on Qwen3-Coder-30B-A3B-Instruct-AWQ
# TP=2 across both 3090s, FP8 KV cache, 64K context (matches vLLM baseline at
# bench-artifacts/2026-05-15-qwen3-coder-30b-a3b-awq/).
#
# SGLang v0.5.11 (lmsysorg/sglang:latest as of 2026-05-15) has historical
# AWQ/compressed-tensors quirks. If startup fails with "VLLM is not installed"
# we fall back to a custom image that pip-installs vllm as a dep.

LAB_NAME=sglang-qwen3-coder-30b-a3b-awq
LAB_IMAGE=docker.io/lmsysorg/sglang:latest
LAB_GPUS=all
LAB_PORT=8011
LAB_API_KEY=lab-sglang-qwen3-coder
LAB_MODEL=QuantTrio/Qwen3-Coder-30B-A3B-Instruct-AWQ
LAB_SERVED_NAME=lab-sglang-qwen3-coder-30b-a3b-awq

LAB_ENV_VARS="SGLANG_USE_AITER=0 TORCH_CUDA_ARCH_LIST=8.6 PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True"

# 32K to match what fits without OOM on TP=2 + flashinfer scratch buffers.
# vLLM equivalent run was at 64K, so we'll note SGLang needs more headroom.
LAB_SGLANG_ARGS="\
  --tp 2 \
  --context-length 32768 \
  --kv-cache-dtype fp8_e5m2 \
  --mem-fraction-static 0.82 \
  --attention-backend flashinfer \
  --tool-call-parser qwen3_coder \
  --trust-remote-code \
  --disable-cuda-graph-padding"
