[Unit]
Description=Homelab vLLM optional Qwen3.5-27B-AWQ long-context lab (port 8002)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=%h/.config/homelab-control/vllm-qwen35-27b-ctx.env
ExecStartPre=/usr/bin/podman rm -f homelab-vllm-qwen35-27b-ctx
ExecStart=/usr/bin/bash -lc '/usr/bin/podman run --name homelab-vllm-qwen35-27b-ctx --replace --device nvidia.com/gpu=all --security-opt=label=disable --ipc=host -p 0.0.0.0:8002:8002 -v %h/.cache/huggingface:/root/.cache/huggingface:Z --env-file %h/.config/homelab-control/vllm-qwen35-27b-ctx.env docker.io/vllm/vllm-openai:v0.19.1 --host 0.0.0.0 --port 8002 --model "$VLLM_Q35_CTX_MODEL" --served-model-name "$VLLM_Q35_CTX_SERVED_MODEL_NAME" --dtype "$VLLM_Q35_CTX_DTYPE" --max-model-len "$VLLM_Q35_CTX_MAX_MODEL_LEN" --gpu-memory-utilization "$VLLM_Q35_CTX_GPU_MEMORY_UTILIZATION" --kv-cache-dtype "$VLLM_Q35_CTX_KV_CACHE_DTYPE" --max-num-batched-tokens "$VLLM_Q35_CTX_MAX_NUM_BATCHED_TOKENS" --max-num-seqs "$VLLM_Q35_CTX_MAX_NUM_SEQS" --enable-prefix-caching --enable-chunked-prefill --api-key "$VLLM_Q35_CTX_API_KEY" $VLLM_Q35_CTX_EXTRA_ARGS'
ExecStop=/usr/bin/podman stop -t 30 homelab-vllm-qwen35-27b-ctx
Restart=on-failure
RestartSec=20

[Install]
WantedBy=default.target
