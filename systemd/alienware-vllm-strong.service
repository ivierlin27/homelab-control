[Unit]
Description=Homelab vLLM strong-model backend (GPU1)
After=network-online.target
Wants=network-online.target
Conflicts=alienware-vllm-strong-long.service

[Service]
Type=simple
EnvironmentFile=%h/.config/homelab-control/vllm-strong.env
ExecStartPre=/usr/bin/podman rm -f homelab-vllm-strong
ExecStart=/usr/bin/bash -lc '/usr/bin/podman run --name homelab-vllm-strong --replace \
  --device "nvidia.com/gpu=${VLLM_STRONG_GPU_DEVICE:-1}" \
  --security-opt=label=disable --ipc=host \
  -p 0.0.0.0:8001:8001 \
  -v /mnt/data/hf-cache:/root/.cache/huggingface:Z \
  -v /mnt/data/tmp:/tmp:Z \
  -e HF_HUB_ENABLE_HF_TRANSFER=1 \
  --env-file %h/.config/homelab-control/vllm-strong.env \
  "${VLLM_STRONG_IMAGE:-docker.io/vllm/vllm-openai:latest}" \
  --host 0.0.0.0 --port 8001 \
  --model "$VLLM_STRONG_MODEL" \
  --served-model-name "$VLLM_STRONG_SERVED_MODEL_NAME" \
  --dtype "$VLLM_STRONG_DTYPE" \
  --max-model-len "$VLLM_STRONG_MAX_MODEL_LEN" \
  --gpu-memory-utilization "$VLLM_STRONG_GPU_MEMORY_UTILIZATION" \
  --kv-cache-dtype "$VLLM_STRONG_KV_CACHE_DTYPE" \
  --max-num-batched-tokens "$VLLM_STRONG_MAX_NUM_BATCHED_TOKENS" \
  --max-num-seqs "$VLLM_STRONG_MAX_NUM_SEQS" \
  --enable-prefix-caching --enable-chunked-prefill \
  --enable-auto-tool-choice --tool-call-parser "${VLLM_STRONG_TOOL_PARSER:-hermes}" \
  --api-key "$VLLM_STRONG_API_KEY" $VLLM_STRONG_EXTRA_ARGS'
ExecStop=/usr/bin/podman stop -t 20 homelab-vllm-strong
Restart=always
RestartSec=10

[Install]
WantedBy=default.target
