[Unit]
Description=Homelab review-agent queue worker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=%h/.config/homelab-control/agent-review.env
ExecStartPre=/usr/bin/bash -lc 'mkdir -p %h/.local/state/homelab-control/agent-review/{inbox,processing,done,failed}'
ExecStart=/usr/bin/bash -lc 'cd "${HOMELAB_CONTROL_ROOT:-%h/homelab-control}" && exec python3 apps/review_agent/main.py worker --queue-dir %h/.local/state/homelab-control/agent-review --heartbeat %h/.local/state/homelab-control/agent-review/heartbeat.json'
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
