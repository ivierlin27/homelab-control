[Unit]
Description=Quarterly DR drill (first Sunday of Jan/Apr/Jul/Oct at 03:00)

[Timer]
# First Sunday of the first month of each calendar quarter
OnCalendar=Sun *-01,04,07,10-01..07 03:00:00
RandomizedDelaySec=30min
Persistent=true
Unit=alienware-backup-dr-drill.service

[Install]
WantedBy=timers.target
