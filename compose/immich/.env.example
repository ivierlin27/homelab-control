# Copy to compose/immich/.env before deploying.
# Keep the database path on local SSD-backed storage, not a network share.

UPLOAD_LOCATION=/srv/immich/library
DB_DATA_LOCATION=/srv/immich/postgres
# TZ=Etc/UTC
IMMICH_VERSION=v2.6.1
DB_PASSWORD=change-me
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
IMMICH_DOMAIN=immich.dev-path.org
